# Exemplo: Caddy com HTTPS automático
# 1) exporte o site: copie a pasta dist/ para /var/www/piffer
# 2) Troque o domínio abaixo
# 3) caddy run --config Caddyfile
# 4) No provedor de DNS, apontando A/AAAA para este servidor

www.exemplo.com.br {
	root * /var/www/piffer/dist
	encode gzip
	try_files {path} /index.html
	file_server
}

exemplo.com.br {
	redir https://www.exemplo.com.br{uri}
}
